# Configuracoes do Telegram
TELEGRAM_API_ID=seu_api_id_aqui
TELEGRAM_API_HASH=seu_api_hash_aqui
PHONE_NUMBER=+55seu_numero_aqui
OWNER_ID=seu_id_telegram_aqui

# Configuracoes de 2FA (opcional)
PASSWORD_2FA=sua_senha_2fa_aqui

# IA Padrao (gemini, deepseek ou openai)
AI_PROVIDER=deepseek

# Chaves de API para cada provedor
# Deixe em branco se nao usar esse provedor

# Google Gemini
# Obter em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_sua_chave_aqui

# DeepSeek
# Obter em: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-sua_chave_aqui

# OpenAI (GPT)
# Obter em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-sua_chave_aqui

# Exemplos:
# Para usar Gemini como padrao:
# AI_PROVIDER=gemini
# GEMINI_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Para usar DeepSeek como padrao:
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Para usar OpenAI como padrao:
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Voce pode configurar multiplas chaves e mudar entre elas com .ai [provider]
