# Configuracoes do Telegram
TELEGRAM_API_ID=seu_api_id_aqui
TELEGRAM_API_HASH=seu_api_hash_aqui
PHONE_NUMBER=+55seu_numero_aqui
OWNER_ID=seu_id_telegram_aqui

# Configuracoes de 2FA (opcional)
PASSWORD_2FA=sua_senha_2fa_aqui

# Configuracoes de IA
# Opcoes: deepseek ou gemini
AI_PROVIDER=deepseek

# Chave da API da IA escolhida
# Para DeepSeek: https://platform.deepseek.com/api_keys
# Para Gemini: https://makersuite.google.com/app/apikey
AI_API_KEY=sua_chave_api_aqui

# Exemplo para DeepSeek:
# AI_PROVIDER=deepseek
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Exemplo para Gemini:
# AI_PROVIDER=gemini
# AI_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
